# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ключ API OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Модель для распознавания текста с фото (vision). По умолчанию: gpt-4o-mini
# OPENAI_OCR_MODEL=gpt-4o-mini

# Модель для проверки диктанта. По умолчанию: gpt-4o-mini
# OPENAI_CHECK_MODEL=gpt-4o-mini

# Публичный URL приложения для webhook. На Railway можно не задавать:
# платформа автоматически задаёт RAILWAY_PUBLIC_DOMAIN, бот соберёт URL сам.
# RAILWAY_PUBLIC_URL=https://your-app.up.railway.app

# Путь для webhook. По умолчанию: webhook
# WEBHOOK_PATH=webhook

# Секрет в URL webhook (опционально). Если задан, URL будет: .../webhook/<значение>
# WEBHOOK_SECRET=

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
